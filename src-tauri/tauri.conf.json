{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "omnimatrix",
  "version": "26.1.0",
  "identifier": "dev.comboom.sucht.OmniMatrix",
  "build": {
    "beforeDevCommand": "pnpm dev --host",
    "devUrl": "http://10.3.1.8:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "enableGTKAppId": true,
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OmniMatrix",
        "width": 800,
        "height": 600,
        "transparent": true,
        "allowLinkPreview": true,
        "browserExtensionsEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/AppIcon.icns"
    ]
  },
  "mainBinaryName": "OmniMatrix"
}
